generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Municipio {
  id                      String           @id @default(uuid())
  nombre                  String
  slug                    String           @unique
  estado                  String           @default("Sonora")
  escudoUrl               String?
  dominio                 String?
  portadaHistoriaUrl      String?
  portadaHistoriaPublicId String?
  activo                  Boolean          @default(true)
  creadoEn                DateTime         @default(now())
  actualizadoEn           DateTime         @updatedAt
  usuarios                Usuario[]
  noticias                Noticia[]
  documentos              Documento[]
  imagenes                Imagen[]
  funcionarios            Funcionario[]
  heroSlides              HeroSlide[]
  sevacDocumentos         SevacDocumento[] @relation("SevacMunicipio")
  contenidosEditables     ContenidoEditable[]
  estadisticas            Estadistica[]
}

model Usuario {
  id           String    @id @default(uuid())
  municipioId  String
  municipio    Municipio @relation(fields: [municipioId], references: [id])
  nombre       String
  email        String    @unique
  passwordHash String
  rol          String    @default("editor")
  activo       Boolean   @default(true)
  creadoEn     DateTime  @default(now())
  ultimoLogin  DateTime?
  // 2FA (TOTP). Campos aditivos: opcionales / con default, no rompen filas
  // existentes. La verificación de TOTP en el login es una fase posterior;
  // por ahora estos campos solo los usan los endpoints /api/auth/2fa/*.
  totpSecret    String?
  totpEnabled   Boolean   @default(false)
  totpEnabledAt DateTime?
  noticias     Noticia[]
}

model Noticia {
  id            String    @id @default(uuid())
  municipioId   String
  municipio     Municipio @relation(fields: [municipioId], references: [id])
  titulo        String
  slug          String
  contenido     String
  extracto      String?
  imagenUrl     String?
  cloudinaryPublicId String?
  categoria     String?
  estado        String    @default("borrador")
  publicarEn    DateTime?
  autorId       String?
  autor         Usuario?  @relation(fields: [autorId], references: [id])
  creadoEn      DateTime  @default(now())
  actualizadoEn DateTime  @updatedAt

  @@unique([municipioId, slug])
}

model Documento {
  id                 String    @id @default(uuid())
  municipioId        String
  municipio          Municipio @relation(fields: [municipioId], references: [id])
  titulo             String
  descripcion        String?
  archivoUrl         String
  tipo               String?
  categoria          String?
  anio               Int?
  trimestre          Int?
  creadoEn           DateTime  @default(now())
  actualizadoEn      DateTime  @default(now()) @updatedAt
  slug               String?
  ambito             String?
  fileSize           Int?
  mimeType           String?
  fileName           String?
  cloudinaryPublicId String?
  portadaUrl         String?
  portadaPublicId    String?
  publicado          Boolean   @default(true)
  orden              Int       @default(0)

  @@index([municipioId, categoria])
  @@index([municipioId, anio, trimestre])
}

model Imagen {
  id           String    @id @default(uuid())
  municipioId  String
  municipio    Municipio @relation(fields: [municipioId], references: [id])
  titulo       String?
  descripcion  String?
  url          String
  urlThumbnail String?
  galeria      String    @default("general")
  altText      String?
  orden        Int       @default(0)
  creadoEn     DateTime  @default(now())
}

enum TipoMiembroCabildo {
  PRESIDENTE
  SINDICA
  REGIDOR
  DIF
  SECRETARIO
  TESORERO
  CONTRALOR
  OTRO
}

model Funcionario {
  id                 String              @id @default(uuid())
  municipioId        String
  municipio          Municipio           @relation(fields: [municipioId], references: [id])
  nombre             String
  cargo              String
  area               String?
  email              String?
  telefono           String?
  fotoUrl            String?
  cloudinaryPublicId String?
  tipo               TipoMiembroCabildo?
  bio                String?
  administracion     String?
  orden              Int                 @default(0)
  activo             Boolean             @default(true)
  creadoEn           DateTime            @default(now())
  actualizadoEn      DateTime            @updatedAt

  @@index([municipioId, tipo, orden])
}

model HeroSlide {
  id            String    @id @default(uuid())
  municipioId   String
  municipio     Municipio @relation(fields: [municipioId], references: [id])
  imagenUrl     String
  etiqueta      String?
  titulo        String
  subtitulo     String?
  textoBoton    String?
  linkBoton     String?
  orden         Int       @default(0)
  activo        Boolean   @default(true)
  creadoEn      DateTime  @default(now())
  actualizadoEn DateTime  @updatedAt
}

model SevacDocumento {
  id                 String    @id @default(uuid())
  municipioId        String
  municipio          Municipio @relation("SevacMunicipio", fields: [municipioId], references: [id])
  titulo             String
  descripcion        String?
  archivoUrl         String
  categoria          String?
  tipo               String?
  anio               Int?
  trimestre          String?
  creadoEn           DateTime  @default(now())
  actualizadoEn      DateTime  @updatedAt
  slug               String?
  fileSize           Int?
  mimeType           String?
  fileName           String?
  cloudinaryPublicId String?
  publicado          Boolean   @default(true)
  orden              Int       @default(0)

  @@index([municipioId, anio, trimestre])
  @@index([municipioId, categoria])
}

// Bloques de contenido editables por CLAVE (encabezados de página y banners).
// Aditivo y multi-tenant: cada municipio tiene su propio juego de claves.
model ContenidoEditable {
  id                 String    @id @default(uuid())
  municipioId        String
  municipio          Municipio @relation(fields: [municipioId], references: [id])
  clave              String
  titulo             String?
  descripcion        String?
  imagenUrl          String?
  cloudinaryPublicId String?
  activo             Boolean   @default(true)
  creadoEn           DateTime  @default(now())
  actualizadoEn      DateTime  @updatedAt

  @@unique([municipioId, clave])
  @@index([municipioId])
}

// Estadísticas del home (cuadros editables). `valor` es String para permitir
// "Por designar" o vacío. Aditivo y multi-tenant.
model Estadistica {
  id                 String    @id @default(uuid())
  municipioId        String
  municipio          Municipio @relation(fields: [municipioId], references: [id])
  titulo             String
  valor              String
  iconoUrl           String?
  cloudinaryPublicId String?
  activo             Boolean   @default(true)
  orden              Int       @default(0)
  creadoEn           DateTime  @default(now())
  actualizadoEn      DateTime  @updatedAt

  @@index([municipioId, orden])
}
